DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/shiftflow
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# AI provider: "gemini" (free-tier pilot default) or "anthropic"
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
# Required only when LLM_PROVIDER=anthropic (or for the employee-message
# parser, which always uses Claude Haiku regardless of LLM_PROVIDER)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram (optional for demo)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Resend (optional for demo)
RESEND_API_KEY=
FROM_EMAIL=noreply@digitalnebula.net

# Redis (optional — in-process fallback used if empty)
REDIS_URL=
